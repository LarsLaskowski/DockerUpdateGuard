{
  "ConnectionStrings": {
    "DockerUpdateGuard": ""
  },
  "DockerUpdateGuard": {
    "ConnectionStringName": "DockerUpdateGuard",
    "Database": {
      "MaxConnectionRetryCount": 8,
      "MaxConnectionRetryDelaySeconds": 30,
      "MigrationStartupTimeoutSeconds": 120,
      "MigrationRetryDelaySeconds": 5
    },
    "DockerHub": {
      "Registry": "docker.io",
      "ApiBaseUrl": "https://hub.docker.com/",
      "UserName": "",
      "Pat": "",
      "RequestTimeoutSeconds": 30,
      "MaxParallelRequests": 4
    },
    "ReleaseMetadata": {
      "DotNetBaseUrl": "https://dotnetcli.blob.core.windows.net/dotnet/release-metadata/",
      "NginxBaseUrl": "https://nginx.org/"
    },
    "Vulnerabilities": {
      "Enabled": false,
      "Provider": "None",
      "TrivyBaseUrl": "",
      "TrivyExecutablePath": "trivy",
      "DockerScoutLoginUrl": "https://hub.docker.com/v2/users/login",
      "DockerScoutBaseUrl": "https://api.scout.docker.com",
      "RequestTimeoutSeconds": 30
    },
    "Scanning": {
      "DiscoveryIntervalMinutes": 15,
      "DockerHubAccountDiscoveryIntervalMinutes": 60,
      "OwnImageBaseScanIntervalMinutes": 60,
      "DockerHubRequestLimitWindowHours": 6,
      "DockerHubRequestLimitPerWindow": 200,
      "DockerHubReservedManualRequestsPerWindow": 40,
      "RuntimeImageUpdateScanIntervalMinutes": 30,
      "ResourceStatisticsIntervalMinutes": 5,
      "VulnerabilityRefreshIntervalMinutes": 180,
      "CleanupIntervalMinutes": 720,
      "RetryCount": 2,
      "RetainScanRunsDays": 30
    },
    "DockerInstances": [
      {
        "Name": "",
        "BaseUrl": "unix:///var/run/docker.sock",
        "Enabled": true,
        "UseTls": false,
        "SkipCertificateValidation": false,
        "CertificatePath": "",
        "RequestTimeoutSeconds": 15,
        "Portainer": {
          "Enabled": false,
          "BaseUrl": "",
          "ApiToken": "",
          "Username": "",
          "Password": "",
          "EndpointId": "",
          "RequestTimeoutSeconds": 15
        }
      }
    ]
  },
  "Telemetry": {
    "ServiceName": "DockerUpdateGuard",
    "Instance": "Production",
    "EnableLogging": true,
    "EnableMetrics": true,
    "EnableTracing": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
