@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="app-layout">
    <MudDrawer @bind-Open="_drawerOpen"
               Breakpoint="Breakpoint.Lg"
               ClipMode="DrawerClipMode.Never"
               Elevation="1"
               Variant="DrawerVariant.Responsive"
               Class="app-drawer">
        <MudStack Spacing="3" Class="app-drawer-content">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="app-brand">
                <MudAvatar Size="Size.Large" Variant="Variant.Filled" Color="Color.Primary" Class="app-brand__avatar">DG</MudAvatar>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">DockerUpdateGuard</MudText>
                    <MudText Typo="Typo.caption">Update visibility</MudText>
                </MudStack>
            </MudStack>

            <NavMenu />
        </MudStack>
    </MudDrawer>

    <MudMainContent Class="app-main-content">
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="page-container">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>