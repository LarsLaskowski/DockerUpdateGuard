@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="app-layout">
    <MudDrawer @bind-Open="_drawerOpen"
               Breakpoint="Breakpoint.Lg"
               ClipMode="DrawerClipMode.Never"
               Elevation="1"
               Variant="DrawerVariant.Responsive"
               Class="app-drawer">
        <MudStack Spacing="3" Class="app-drawer-content">
            <NavMenu />
        </MudStack>
    </MudDrawer>

    <MudMainContent Class="app-main-content">
        <MudPaper Class="app-topbar" Elevation="0">
            <div class="app-topbar__content">
                <div class="app-topbar__brand">
                    <MudIconButton Icon="@Icons.Material.Filled.Menu"
                                   Color="Color.Inherit"
                                   OnClick="ToggleDrawer"
                                   Class="app-topbar__menu-button"
                                   aria-label="Toggle navigation" />
                    <img src="@Assets["logo-dg-shield.svg"]" alt="DockerUpdateGuard logo" class="app-brand__logo app-topbar__logo" />
                    <MudText Typo="Typo.h5" Class="app-brand__title app-topbar__title">DockerUpdateGuard</MudText>
                </div>

                @if (_dashboardSummary is null)
                {
                    <MudText Class="muted-text app-topbar__status">Loading dashboard summary...</MudText>
                }
                else
                {
                    <div class="app-topbar__meta">
                        <MudPaper Class="hero-meta-card app-topbar__meta-card" Elevation="0">
                            <MudText Typo="Typo.caption" Class="muted-text">Protected assets</MudText>
                            <MudText Typo="Typo.h6">@GetProtectedAssetCount()</MudText>
                        </MudPaper>
                        <MudPaper Class="hero-meta-card app-topbar__meta-card" Elevation="0">
                            <MudText Typo="Typo.caption" Class="muted-text">Last activity</MudText>
                            <MudText Typo="Typo.h6">@GetLatestScanLabel()</MudText>
                        </MudPaper>
                    </div>
                }
            </div>
        </MudPaper>

        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="page-container">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
