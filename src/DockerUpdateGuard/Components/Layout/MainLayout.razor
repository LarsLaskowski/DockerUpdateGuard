@inherits LayoutComponentBase

<MudThemeProvider @ref="_themeProvider" Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="@GetLayoutClass()">
    <MudDrawer @bind-Open="_drawerOpen"
               Breakpoint="Breakpoint.Lg"
               ClipMode="DrawerClipMode.Never"
               Elevation="1"
               Variant="DrawerVariant.Responsive"
               Class="app-drawer">
        <MudStack Spacing="3" Class="app-drawer-content">
            <NavMenu />
        </MudStack>
    </MudDrawer>

    <MudMainContent Class="app-main-content">
        <MudPaper Class="app-topbar" Elevation="0">
            <div class="app-topbar__content">
                <div class="app-topbar__brand">
                    <MudIconButton Icon="@Icons.Material.Filled.Menu"
                                   Color="Color.Inherit"
                                   OnClick="ToggleDrawer"
                                   Class="app-topbar__menu-button"
                                   aria-label="Toggle navigation" />
                    <img src="@Assets["logo-dg-shield.svg"]" alt="DockerUpdateGuard logo" class="app-brand__logo app-topbar__logo" />
                    <MudText Typo="Typo.h5" Class="app-brand__title app-topbar__title">DockerUpdateGuard</MudText>
                </div>

                <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                               Color="Color.Inherit"
                               OnClick="ToggleDarkModeAsync"
                               Class="app-topbar__theme-toggle"
                               aria-label="Toggle dark mode" />

                @if (_dashboardSummary is null)
                {
                    <MudSkeleton Width="140px" Height="32px" Class="app-topbar__status-skeleton" />
                }
                else
                {
                    <div class="app-topbar__meta app-topbar__meta--full">
                        <MudPaper Class="hero-meta-card app-topbar__meta-card" Elevation="0">
                            <MudText Typo="Typo.caption" Class="muted-text">Protected assets</MudText>
                            <MudText Typo="Typo.h6">@GetProtectedAssetCount()</MudText>
                        </MudPaper>
                        <MudPaper Class="hero-meta-card app-topbar__meta-card" Elevation="0">
                            <MudText Typo="Typo.caption" Class="muted-text">Last activity</MudText>
                            <MudText Typo="Typo.h6">@GetLatestScanLabel()</MudText>
                        </MudPaper>
                    </div>

                    <div class="app-topbar__meta--compact">
                        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                            <ActivatorContent>
                                <MudChip T="string"
                                         Icon="@Icons.Material.Filled.Shield"
                                         Color="Color.Primary"
                                         Class="app-topbar__pill"
                                         aria-label="Show protected asset metrics">@GetProtectedAssetCount()</MudChip>
                            </ActivatorContent>
                            <ChildContent>
                                <div class="app-topbar__meta-popover">
                                    <div class="app-topbar__meta-popover-item">
                                        <MudText Typo="Typo.caption" Class="muted-text">Protected assets</MudText>
                                        <MudText Typo="Typo.h6">@GetProtectedAssetCount()</MudText>
                                    </div>
                                    <div class="app-topbar__meta-popover-item">
                                        <MudText Typo="Typo.caption" Class="muted-text">Last activity</MudText>
                                        <MudText Typo="Typo.h6">@GetLatestScanLabel()</MudText>
                                    </div>
                                </div>
                            </ChildContent>
                        </MudMenu>
                    </div>
                }
            </div>
        </MudPaper>

        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="page-container">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
