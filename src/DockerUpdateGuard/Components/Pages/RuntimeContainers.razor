@page "/runtime-containers"

<PageTitle>Runtime Containers</PageTitle>

<MudStack Spacing="3" Class="page-shell">
    <div class="page-header">
        <div>
            <MudText Typo="Typo.overline" Class="page-eyebrow">Live workloads</MudText>
            <MudText Typo="Typo.h3">Runtime Containers</MudText>
            <MudText Class="page-description">Review active containers, their source images, and the current update posture.</MudText>
        </div>
    </div>

    @if (_containers is null)
    {
        <MudPaper Class="empty-state-panel" Elevation="0">
            <MudText>Loading runtime containers...</MudText>
        </MudPaper>
    }
    else if (_containers.Count == 0)
    {
        <MudPaper Class="empty-state-panel" Elevation="0">
            <MudText>No runtime containers have been observed yet.</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="section-paper" Elevation="0">
            <div class="section-header">
                <MudText Typo="Typo.h5">Container inventory</MudText>
                <MudText Class="section-description">Current runtime state correlated with update and vulnerability results.</MudText>
            </div>
            <MudTable Items="_containers" Hover="true" Dense="false" Breakpoint="Breakpoint.Md" Class="section-table">
                <HeaderContent>
                    <MudTh>Container</MudTh>
                    <MudTh>Instance</MudTh>
                    <MudTh>Image</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Update State</MudTh>
                    <MudTh>Vulnerabilities</MudTh>
                    <MudTh>Portainer</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Container">
                        <MudLink Href="@($"runtime-containers/{context.DockerInstanceId}/{context.ContainerId}")" Class="table-link">@context.ContainerName</MudLink>
                        <span class="table-secondary">@context.RecordedAtUtc.ToLocalTime().ToString("g")</span>
                    </MudTd>
                    <MudTd DataLabel="Instance">@context.DockerInstanceName</MudTd>
                    <MudTd DataLabel="Image">
                        <span>@ImageReferenceFormatter.GetReference(context.ImageReference)</span>
                        @if (ImageReferenceFormatter.GetFullDigest(context.ImageReference) is string fullDigest)
                        {
                            <MudTooltip Text="@fullDigest">
                                <span class="table-secondary">@("@" + ImageReferenceFormatter.GetShortDigest(context.ImageReference))</span>
                            </MudTooltip>
                        }
                    </MudTd>
                    <MudTd DataLabel="Status">@context.RuntimeStatus</MudTd>
                    <MudTd DataLabel="Update State">
                        <MudChip T="string" Size="Size.Small" Color="@GetUpdateStateColor(context.UpdateState)">@context.UpdateState</MudChip>
                        <span class="table-secondary">@context.UpdateSummary</span>
                    </MudTd>
                    <MudTd DataLabel="Vulnerabilities">
                        <MudChip T="string" Size="Size.Small" Color="@GetVulnerabilityStatusColor(context.VulnerabilityStatus)">@context.VulnerabilityStatus</MudChip>
                        <span class="table-secondary">@($"{context.ActiveVulnerabilityFindingCount} active · {context.VulnerabilitySummary}")</span>
                    </MudTd>
                    <MudTd DataLabel="Portainer">
                        <MudChip T="string" Size="Size.Small" Color="@(context.PortainerAvailable ? Color.Success : Color.Default)">
                            @(context.PortainerAvailable ? "Configured" : "Unavailable")
                        </MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</MudStack>
