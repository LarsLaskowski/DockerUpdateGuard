@page "/runtime-containers"

<PageTitle>Runtime Containers</PageTitle>

<MudStack Spacing="3" Class="page-shell">
    <div class="page-header">
        <div>
            <MudText Typo="Typo.overline" Class="page-eyebrow">Live workloads</MudText>
            <MudText Typo="Typo.h3">Runtime Containers</MudText>
            <MudText Class="page-description">Review active containers, their source images, own-image shortcuts, and live resource usage.</MudText>
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@_isBusy"
                   OnClick="TriggerScanAsync">
            @if (_isBusy)
            {
                <MudProgressCircular Class="me-2"
                                     Size="Size.Small"
                                     Indeterminate="true"
                                     Color="Color.Inherit" />
                <span>Checking image updates...</span>
            }
            else
            {
                <span>Check image updates</span>
            }
        </MudButton>
    </div>

    @if (string.IsNullOrWhiteSpace(_errorMessage) == false)
    {
        <MudAlert Severity="Severity.Error" Dense="true">@_errorMessage</MudAlert>
    }

    @if (_containers is null)
    {
        <MudPaper Class="empty-state-panel" Elevation="0">
            <MudText>Loading runtime containers...</MudText>
        </MudPaper>
    }
    else if (_containers.Count == 0)
    {
        <MudPaper Class="empty-state-panel" Elevation="0">
            <MudText>No runtime containers have been observed yet.</MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="section-paper" Elevation="0">
            <div class="section-header">
                <MudText Typo="Typo.h5">Container inventory</MudText>
                <MudText Class="section-description">Current runtime state correlated with own-image shortcuts, update results, vulnerabilities, and resource usage.</MudText>
            </div>
            <MudTable Items="_containers" Hover="true" Dense="false" Breakpoint="Breakpoint.Md" Class="section-table runtime-containers-table">
                <HeaderContent>
                    <MudTh>Container</MudTh>
                    <MudTh>Instance</MudTh>
                    <MudTh Class="runtime-containers-table__resource">CPU</MudTh>
                    <MudTh Class="runtime-containers-table__resource">Memory</MudTh>
                    <MudTh Class="runtime-containers-table__resource">Network</MudTh>
                    <MudTh Class="runtime-containers-table__update-state">Update State</MudTh>
                </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Container">
                            <div class="runtime-containers-table__name">
                                <MudLink Href="@($"/runtime-containers/{context.DockerInstanceId}/{context.ContainerId}")" Class="table-link">@context.ContainerName</MudLink>
                                @if (context.LinkedObservedImageId is Guid observedImageId)
                                {
                                    <MudTooltip Text="@($"Open own image '{context.LinkedObservedImageName ?? "linked image"}'")">
                                        <MudLink Href="@($"/observed-images/{observedImageId}")" Class="runtime-containers-table__name-icon-link">
                                            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" Class="runtime-containers-table__name-icon" />
                                        </MudLink>
                                    </MudTooltip>
                                }
                            </div>
                            @if (string.IsNullOrWhiteSpace(context.ResolvedVersionTag))
                            {
                                <span class="table-secondary">@context.CurrentTag</span>
                            }
                            else
                            {
                                <span class="table-secondary">@($"{context.CurrentTag} ({context.ResolvedVersionTag})")</span>
                            }
                            <span class="table-secondary">@context.RecordedAtUtc.ToLocalTime().ToString("g")</span>
                        </MudTd>
                        <MudTd DataLabel="Instance">@context.DockerInstanceName</MudTd>
                        <MudTd DataLabel="CPU" Class="runtime-containers-table__resource">
                            <div>@FormatCpu(context.CurrentResourceUsage)</div>
                            @if (HasResourceHistory(context))
                            {
                                <div class="runtime-containers-table__sparkline">
                                    <svg viewBox="0 0 100 26" preserveAspectRatio="none" aria-hidden="true">
                                        <path d="@GetCpuSparklinePath(context)" class="runtime-containers-table__sparkline-line runtime-containers-table__sparkline-line--cpu"></path>
                                    </svg>
                                </div>
                            }
                        </MudTd>
                        <MudTd DataLabel="Memory" Class="runtime-containers-table__resource">
                            <div>@FormatMemory(context.CurrentResourceUsage)</div>
                            @if (HasResourceHistory(context))
                            {
                                <div class="runtime-containers-table__sparkline">
                                    <svg viewBox="0 0 100 26" preserveAspectRatio="none" aria-hidden="true">
                                        <path d="@GetMemorySparklinePath(context)" class="runtime-containers-table__sparkline-line runtime-containers-table__sparkline-line--memory"></path>
                                    </svg>
                                </div>
                            }
                        </MudTd>
                        <MudTd DataLabel="Network" Class="runtime-containers-table__resource">
                            <div>@FormatNetwork(context.CurrentResourceUsage)</div>
                            @if (HasResourceHistory(context))
                            {
                                <div class="runtime-containers-table__sparkline">
                                    <svg viewBox="0 0 100 26" preserveAspectRatio="none" aria-hidden="true">
                                        <path d="@GetNetworkReceiveSparklinePath(context)" class="runtime-containers-table__sparkline-line runtime-containers-table__sparkline-line--network-rx"></path>
                                        <path d="@GetNetworkTransmitSparklinePath(context)" class="runtime-containers-table__sparkline-line runtime-containers-table__sparkline-line--network-tx"></path>
                                    </svg>
                                </div>
                            }
                        </MudTd>
                        <MudTd DataLabel="Update State" Class="runtime-containers-table__update-state">
                            <MudChip T="string" Size="Size.Small" Color="@GetUpdateStateColor(context.UpdateState)">@context.UpdateState</MudChip>
                            @if (string.IsNullOrWhiteSpace(context.AvailableUpdateVersionTag) == false)
                            {
                                <span class="table-secondary">@context.AvailableUpdateVersionTag</span>
                            }
                            @if (context.ActiveVulnerabilityFindingCount > 0)
                            {
                                <MudChip T="string" Size="Size.Small" Color="@GetVulnerabilityStatusColor(context.VulnerabilityStatus)">Runtime vulnerabilities</MudChip>
                                <span class="table-secondary">@($"{context.ActiveVulnerabilityFindingCount} active · {context.VulnerabilitySummary}")</span>
                            }
                            @if (context.ActiveBaseImageVulnerabilityFindingCount > 0)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">Base images affected</MudChip>
                                <span class="table-secondary">@context.BaseImageVulnerabilitySummary</span>
                            }
                        </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</MudStack>
