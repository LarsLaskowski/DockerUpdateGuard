# Copy this file to .env and adjust the values before running docker compose.
#
#   cp .env.example .env
#
# .env stays next to the docker-compose*.yml file and is loaded automatically
# by "docker compose". Do not commit the real .env file.

# --- PostgreSQL ---------------------------------------------------------
POSTGRES_DB=dockerupdateguard
POSTGRES_USER=dockerupdateguard
POSTGRES_PASSWORD=change-me

# --- Docker socket access ------------------------------------------------
# GID of the "docker" group that owns /var/run/docker.sock on the host.
# Find it with:
#   stat -c '%g' /var/run/docker.sock
# On systems where the socket is owned by root:root (e.g. Synology DSM),
# the default of 0 already works and this value can be left as-is.
DOCKER_GID=0

# --- Docker Hub (optional) -----------------------------------------------
# Only needed for authenticated Docker Hub API access (higher rate limits,
# private repositories). Leave empty to use anonymous access.
DOCKERHUB_USERNAME=
DOCKERHUB_PAT=
